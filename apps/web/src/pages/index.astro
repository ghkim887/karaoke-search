---
import { App } from '../components/App';
import Footer from '../components/Footer.astro';
const title = '일본 노래 검색기';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <style is:global>
      /* Self-hosted webfonts. Geist (display) + Inter (body) — both OFL/MIT.
         Files live at /fonts/ relative to the site root. font-display: swap so
         CJK fallback text never blocks paint while the woff2 loads.

         Vite emits a warning per @font-face url at build time
         ("/karaoke-search/fonts/<name>.woff2 didn't resolve at build time, it
         will remain unchanged to be resolved at runtime"). The warning is
         benign — these are absolute public-asset paths served at runtime via
         Astro's `base: '/karaoke-search/'`, and `dist/fonts/` contains every
         referenced file. See review H1. */
      @font-face {
        font-family: 'Geist';
        src: url('/karaoke-search/fonts/geist-500.woff2') format('woff2');
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Inter';
        src: url('/karaoke-search/fonts/inter-400.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Inter';
        src: url('/karaoke-search/fonts/inter-500.woff2') format('woff2');
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Inter';
        src: url('/karaoke-search/fonts/inter-600.woff2') format('woff2');
        font-weight: 600;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Pretendard';
        src: url('/karaoke-search/fonts/pretendard-400.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Pretendard';
        src: url('/karaoke-search/fonts/pretendard-500.woff2') format('woff2');
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Pretendard';
        src: url('/karaoke-search/fonts/pretendard-600.woff2') format('woff2');
        font-weight: 600;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Pretendard';
        src: url('/karaoke-search/fonts/pretendard-700.woff2') format('woff2');
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }
      :root {
        /* Revolut-strict surface tokens (dark default).
           Every value is either directly from DESIGN.md §2 or derived
           from DESIGN.md's Ghost-on-Dark §4 Buttons pattern (the only place
           DESIGN.md defines dark elevated treatment). No invented colors. */
        --rui-bg: #191c1f;                                /* Revolut Dark §2 Primary */
        --rui-surface: rgba(244, 244, 244, 0.06);         /* Ghost-on-Dark style overlay */
        --rui-surface-hover: rgba(244, 244, 244, 0.10);   /* Ghost-on-Dark BG §4 */
        --rui-fg: #f4f4f4;                                /* Ghost-on-Dark text §4 */
        --rui-fg-muted: #8d969e;                          /* Cool Gray §2 Neutral */
        --rui-fg-subtle: #505a63;                         /* Mid Slate §2 Neutral */
        --rui-border: rgba(244, 244, 244, 0.16);          /* derived from grey-tone-20 luminance */
        --rui-border-strong: #f4f4f4;                     /* Ghost-on-Dark border §4 */
        --rui-pill-primary-bg: #f4f4f4;                   /* Light Surface §2, inverted for dark */
        --rui-pill-primary-fg: #191c1f;                   /* Revolut Dark */
        --rui-pill-secondary-bg: rgba(244, 244, 244, 0.10); /* Ghost-on-Dark BG */
        --rui-pill-secondary-fg: #f4f4f4;
        --rui-pill-ghost-bg: transparent;
        --rui-radius-pill: 9999px;                        /* §4 / §5 */
        --rui-radius-card: 20px;                          /* §4 Cards & Containers */
        --rui-radius-small: 12px;                         /* §4 Cards & Containers */
        --rui-focus-ring: 0 0 0 0.125rem var(--rui-fg);   /* §6 Focus */

        /* Typography stacks */
        --rui-font-display: 'Geist', 'Pretendard', system-ui, sans-serif;
        --rui-font-body: "Inter", "Pretendard", system-ui, "Noto Sans KR", "Noto Sans JP", sans-serif;

        /* DESIGN.md §3 Typography hierarchy — adopted verbatim. */
        --rui-text-card-title: 32px;     /* §3 Card Title — used for page H1 in Restrained Revolut */
        --rui-text-feature-title: 24px;  /* §3 Feature Title — mobile fallback for page H1 */
        --rui-text-nav: 20px;            /* §3 Nav / UI */
        --rui-text-body-large: 18px;     /* §3 Body Large */
        --rui-text-body: 16px;           /* §3 Body — STANDARD reading text */

        /* Resolved height of header.site-header. Declared on :root so it
           inherits down into <main>, which is a sibling (not a descendant)
           of <header>. Mobile baseline; the desktop breakpoint below bumps
           it for the larger H1. */
        --header-height: 6rem;  /* ~96px mobile — site-title 24px×1.33 + subtitle 16px×1.5 + 18px×2 padding */
      }

      @media (prefers-color-scheme: light) {
        :root {
          --rui-bg: #ffffff;                              /* Pure White §2 Primary */
          --rui-surface: #f4f4f4;                         /* Light Surface §2 Primary */
          --rui-surface-hover: #ececef;                   /* derived darker tint */
          --rui-fg: #191c1f;                              /* Revolut Dark §2 Primary */
          --rui-fg-muted: #505a63;                        /* Mid Slate §2 Neutral */
          --rui-fg-subtle: #8d969e;                       /* Cool Gray §2 Neutral */
          --rui-border: #c9c9cd;                          /* Gray Tone §2 Neutral (rui-color-grey-tone-20) */
          --rui-border-strong: #191c1f;                   /* Outlined Pill border §4 */
          --rui-pill-primary-bg: #191c1f;                 /* Primary Dark Pill BG §4 */
          --rui-pill-primary-fg: #ffffff;                 /* Primary Dark Pill TX §4 */
          --rui-pill-secondary-bg: #f4f4f4;               /* Secondary Light Pill BG §4 */
          --rui-pill-secondary-fg: #000000;               /* Secondary Light Pill TX §4 — yes #000 per DESIGN.md */
          --rui-pill-ghost-bg: transparent;               /* Outlined Pill BG §4 */
          --rui-focus-ring: 0 0 0 0.125rem var(--rui-fg);
        }
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background: var(--rui-bg);
        color: var(--rui-fg);
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body — 16px / 1.5 / 0.24px */
        font-size: var(--rui-text-body);
        line-height: 1.5;
        letter-spacing: 0.24px;
      }

      header.site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--rui-bg);
        padding: 1.125rem 1.25rem;
      }

      .site-title {
        margin: 0;
        font-family: var(--rui-font-display);
        /* DESIGN.md §3 Card Title — 32px / 500 / 1.19 / -0.32px (desktop)
           Mobile fallback: §3 Feature Title — 24px / 500 / 1.33 / 0px. */
        font-size: var(--rui-text-feature-title);
        font-weight: 500;
        line-height: 1.33;
        letter-spacing: 0px;
        color: var(--rui-fg);
      }

      @media (min-width: 720px) {
        :root {
          --header-height: 6.5rem;  /* ~104px desktop — site-title 32px×1.19 + subtitle 16px×1.5 + 18px×2 padding */
        }

        .site-title {
          font-size: var(--rui-text-card-title);
          line-height: 1.19;
          letter-spacing: -0.32px;
        }
      }

      .site-subtitle {
        margin: 4px 0 0 0;
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body — 16px / 400 / 1.5 / 0.24px */
        font-size: var(--rui-text-body);
        font-weight: 400;
        line-height: 1.5;
        letter-spacing: 0.24px;
        color: var(--rui-fg-muted);
      }

      .tab-bar {
        position: sticky;
        top: var(--header-height, 6rem);
        z-index: 9;
        display: flex;
        gap: 24px;
        width: 100%;
        margin: 0 0 1rem;
        padding: 0;
        background: var(--rui-bg);
        border-bottom: 1px solid var(--rui-border);
      }

      .tab-button {
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body — 16px. Inactive uses weight 500 (between Body 400
           and Body Semibold 600) so the active/inactive contrast reads. */
        font-size: var(--rui-text-body);
        font-weight: 500;
        padding: 10px 4px;
        background: transparent;
        color: var(--rui-fg-muted);
        border: 0;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        border-radius: 0;
        cursor: pointer;
        outline: none;
        letter-spacing: 0.24px;
        transition:
          color 120ms ease,
          border-color 120ms ease;
      }

      .tab-button:hover:not(:disabled) {
        color: var(--rui-fg);
      }

      .tab-button:focus-visible {
        outline: none;
        box-shadow: var(--rui-focus-ring);
      }

      .tab-button-active,
      .tab-button[aria-selected='true'] {
        color: var(--rui-fg);
        /* DESIGN.md §3 Body Semibold — 600 */
        font-weight: 600;
        border-bottom-color: var(--rui-fg);
      }

      .tab-button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      .search-input-wrap {
        position: relative;
        max-width: 640px;
        padding-bottom: 0.5rem;
      }

      .search-input-icon {
        position: absolute;
        top: 50%;
        left: 1.1rem;
        transform: translateY(-50%);
        color: var(--rui-fg-subtle);
        pointer-events: none;
      }

      input.search-input {
        width: 100%;
        max-width: 640px;
        height: 48px;
        padding: 0 1.25rem 0 2.75rem;
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body — 16px / 400 / 0.24px */
        font-size: var(--rui-text-body);
        font-weight: 400;
        letter-spacing: 0.24px;
        color: var(--rui-fg);
        background: var(--rui-surface);
        border: 1px solid var(--rui-border);
        border-radius: var(--rui-radius-pill);
        outline: none;
        transition:
          border-color 120ms ease,
          background 120ms ease;
      }

      input.search-input::placeholder {
        color: var(--rui-fg-subtle);
      }

      input.search-input:focus-visible {
        outline: none;
        box-shadow: var(--rui-focus-ring);
        border-color: var(--rui-border-strong);
      }

      main.results {
        padding: 1.25rem;
        max-width: 960px;
        margin: 0 auto;
      }

      main.results .loading,
      main.results .error {
        color: var(--rui-fg-muted);
        /* DESIGN.md §3 Body — 16px */
        font-size: var(--rui-text-body);
      }

      main.results .error {
        color: var(--rui-fg);
      }

      @keyframes karaoke-dot-cycle {
        0%,
        100% {
          opacity: 0.2;
        }
        50% {
          opacity: 1;
        }
      }

      .loading-dot {
        display: inline-block;
        animation: karaoke-dot-cycle 1.2s infinite ease-in-out;
        font-weight: 600;
      }

      .loading-dot:nth-child(1) {
        animation-delay: 0s;
      }
      .loading-dot:nth-child(2) {
        animation-delay: 0.4s;
      }
      .loading-dot:nth-child(3) {
        animation-delay: 0.8s;
      }

      .chip-group {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 0.75rem 0 1.25rem;
        padding: 0;
        border: 0;
      }

      .chip-group-legend {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        border: 0;
      }

      /* DESIGN.md §4 Secondary Light Pill — 14px 32px padding, 9999px radius.
         All `.chip` instances render as Secondary pills by default; the vendor
         chip group (`.chip-group-vendor`) overrides with the §4 Outlined Pill
         treatment to differentiate visual rank from category chips. */
      .chip {
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body Semibold — 16px / 600 / 1.5 / 0.16px */
        font-size: var(--rui-text-body);
        font-weight: 600;
        line-height: 1.5;
        letter-spacing: 0.16px;
        padding: 14px 32px;
        border-radius: var(--rui-radius-pill);
        border: 2px solid transparent;
        background: var(--rui-pill-secondary-bg);
        color: var(--rui-pill-secondary-fg);
        cursor: pointer;
        transition: opacity 120ms ease;
      }

      .chip:hover {
        /* DESIGN.md §4 — pill hover is opacity 0.85 */
        opacity: 0.85;
      }

      .chip:focus-visible {
        outline: none;
        box-shadow: var(--rui-focus-ring);
      }

      .chip-selected,
      .chip-selected:hover {
        background: var(--rui-pill-primary-bg);
        color: var(--rui-pill-primary-fg);
      }

      /* DESIGN.md §4 Outlined Pill — transparent BG, 2px solid border-strong. */
      .chip-group-vendor .chip {
        background: var(--rui-pill-ghost-bg);
        color: var(--rui-fg);
        border-color: var(--rui-border-strong);
      }

      .chip-group-vendor .chip-selected,
      .chip-group-vendor .chip-selected:hover {
        background: var(--rui-pill-primary-bg);
        color: var(--rui-pill-primary-fg);
        border-color: var(--rui-pill-primary-bg);
      }

      .empty-state {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
      }

      /* Off-table small uppercase label — DESIGN.md §3 has no caption scale.
         Documented deviation: 12px Inter 500 uppercase with 0.6px tracking. */
      .empty-section-title {
        margin: 16px 0 12px;
        font-family: var(--rui-font-body);
        font-size: 12px;
        font-weight: 500;
        line-height: 1.4;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        color: var(--rui-fg-muted);
      }

      .empty-section-title-jpop,
      .empty-section-title-vocaloid,
      .empty-section-title-anime,
      .empty-favorites-title {
        color: var(--rui-fg-muted);
      }

      /* DESIGN.md §5 — base 8px spacing scale. Pills wrap rather than scroll. */
      .empty-section-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .empty-section-placeholder {
        margin: 0;
        color: var(--rui-fg-muted);
        /* DESIGN.md §3 Body — 16px */
        font-size: var(--rui-text-body);
      }

      /* DESIGN.md §4 Secondary Light Pill (light) / Ghost-on-Dark (dark) —
         the secondary pill tokens already invert by theme. */
      .featured-chip {
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body Semibold — 16px / 600 / 1.5 / 0.16px */
        font-size: var(--rui-text-body);
        font-weight: 600;
        line-height: 1.5;
        letter-spacing: 0.16px;
        padding: 14px 32px;
        border-radius: var(--rui-radius-pill);
        border: 2px solid transparent;
        background: var(--rui-pill-secondary-bg);
        color: var(--rui-pill-secondary-fg);
        cursor: pointer;
        transition: opacity 120ms ease;
      }

      .featured-chip:hover {
        /* DESIGN.md §4 — pill hover is opacity 0.85 */
        opacity: 0.85;
      }

      .featured-chip:focus-visible {
        outline: none;
        box-shadow: var(--rui-focus-ring);
      }

      .no-results {
        text-align: center;
        color: var(--rui-fg-muted);
        padding: 2rem 1rem;
      }

      .no-results-title {
        margin: 0 0 0.5rem;
        font-family: var(--rui-font-display);
        /* DESIGN.md §3 Feature Title — 24px / 500 / 1.33 / 0px */
        font-size: var(--rui-text-feature-title);
        font-weight: 500;
        line-height: 1.33;
        letter-spacing: 0px;
        color: var(--rui-fg);
      }

      .favorites-empty {
        text-align: center;
        color: var(--rui-fg-muted);
        padding: 2rem 1rem;
        /* DESIGN.md §3 Body — 16px */
        font-size: var(--rui-text-body);
        line-height: 1.5;
        letter-spacing: 0.24px;
      }

      .result-list {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.75rem;
        list-style: none;
        margin: 0;
        padding: 0;
        /* Path A — stretch all cards in a row to the tallest card's height so
           variable-height titles do not break the grid. The vendor-numbers row
           inside `.result-card` then uses `margin-top: auto` to flush to the
           card's bottom edge. Result: the bottom edge of every card in a row
           aligns. */
        align-items: stretch;
      }

      @media (min-width: 720px) {
        .result-list {
          grid-template-columns: 1fr 1fr;
        }
      }

      /* Stretch the <li> wrapper to fill the grid track so the inner card can
         claim full row height. Without this, `align-items: stretch` on the
         grid stretches the <li> but `.result-card` would still hug its content
         inside that <li> unless the <li> propagates height. */
      .result-list-item {
        display: flex;
      }

      .result-list-item .result-card {
        flex: 1;
      }

      @media (max-width: 719px) {
        /* Mobile compact sizing — surgical scale-down from DESIGN.md tablet+ spec.
           Tablet+ (≥720px) retains the generous DESIGN.md 14px 32px / 16px 600 spec.
           Mobile chip sizing: 6px 14px / 14px 500. */

        /* Category + vendor chips */
        .chip {
          padding: 6px 14px;
          font-size: 14px;
          font-weight: 500;
          letter-spacing: 0.16px;
        }

        /* In-row gap between chips (category row and vendor row each) */
        .chip-group {
          gap: 6px;
        }

        /* Inter-row gap between category chip row and vendor chip row */
        .chip-group + .chip-group {
          margin-top: 8px;
        }

        /* Featured-artist strip — one-row horizontal scroll, no wrap */
        .empty-section-chips {
          flex-wrap: nowrap;
          overflow-x: auto;
          gap: 6px;
          padding-bottom: 4px;
          -webkit-overflow-scrolling: touch;
        }

        /* Compact featured-chip */
        .featured-chip {
          padding: 6px 14px;
          font-size: 14px;
          font-weight: 500;
          letter-spacing: 0.16px;
        }

        /* Tighten the gap between chip block and the first featured-strip section */
        .chip-group ~ .empty-state {
          margin-top: 12px;
        }

        .badge-number {
          min-height: 44px;
        }

        .result-numbers {
          gap: 0.5rem;
          padding: 0.4rem 0;
        }

        .favorite-star {
          min-width: 44px;
          min-height: 44px;
        }
      }

      .result-card {
        position: relative;
        background: var(--rui-surface);
        border-radius: var(--rui-radius-card);
        /* DESIGN.md §5 spacing scale — 16px (was 14px 16px which is off-scale
           on the vertical axis). 16px on both axes matches the Revolut card
           rhythm. */
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        /* Path A — fill the grid track height so all cards in a row align at
           the bottom edge. */
        height: 100%;
        transition: background 120ms ease;
      }

      .result-card:hover {
        background: var(--rui-surface-hover);
      }

      .favorite-star {
        position: absolute;
        top: 0.75rem;
        right: 0.85rem;
        font-family: var(--rui-font-body);
        font-size: 1.125rem;
        line-height: 1;
        background: transparent;
        border: 0;
        padding: 0.25rem 0.4rem;
        cursor: pointer;
        /* Inactive: visibly present but de-emphasized — DESIGN.md §2 Mid Slate
           via --rui-fg-subtle. */
        color: var(--rui-fg-subtle);
        transition:
          color 120ms ease,
          opacity 120ms ease;
      }

      .favorite-star:hover {
        /* DESIGN.md §4 — interactive hover is opacity 0.85. */
        opacity: 0.85;
      }

      .favorite-star:focus-visible {
        outline: none;
        box-shadow: var(--rui-focus-ring);
        border-radius: var(--rui-radius-small);
      }

      /* Active: full --rui-fg foreground per brief. */
      .favorite-star-on {
        color: var(--rui-fg);
      }

      .favorite-star-on:hover {
        color: var(--rui-fg);
        opacity: 0.85;
      }

      .result-title {
        margin: 0;
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body Semibold — 16px / 600 / 1.5 / 0.16px */
        font-size: var(--rui-text-body);
        font-weight: 600;
        line-height: 1.5;
        letter-spacing: 0.16px;
        color: var(--rui-fg);
        padding-right: 2.25rem;
      }

      .result-artist {
        color: var(--rui-fg-muted);
        /* DESIGN.md §3 Body — 16px / 400 / 1.5 / 0.24px. Strict scale; if the
           list density looks too dense, the brief calls for flagging — do not
           silently shrink. */
        font-size: var(--rui-text-body);
        font-weight: 400;
        line-height: 1.5;
        letter-spacing: 0.24px;
      }

      .result-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 4px 10px;
        border-radius: var(--rui-radius-small);
        background: var(--rui-surface);
        font-family: var(--rui-font-body);
        /* Off-table small uppercase label — DESIGN.md §3 has no caption scale.
           Documented deviation: 12px Inter 500 uppercase with 0.6px tracking. */
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        color: var(--rui-fg-muted);
      }

      /* DESIGN.md §4 Secondary Pill treatment — scaled down for inline content
         tag use. Deviations from §4 baseline (documented):
           - Padding: 6px 14px (vs §4's 14px 32px) — this is an inline tag
             inside a card, NOT a primary CTA. Generous CTA padding would
             dominate the card row.
           - Typography: 12px / 500 / 0.6px tracking, uppercase (vs §3 Body
             Semibold 16px / 600 / 0.16px) — picks the small uppercase caption
             treatment used elsewhere on small inline labels (`.badge-label`,
             `.empty-section-title`). 16px would overflow the card row at 3
             tags + a category chip.
           - No border (per brief — Secondary Pill has no border in either
             theme).
           - No opacity hover — this is a non-interactive `<span>`. */
      .badge-category {
        background: var(--rui-pill-secondary-bg);
        color: var(--rui-pill-secondary-fg);
        border-radius: var(--rui-radius-pill);
        padding: 6px 14px;
        text-transform: uppercase;
      }

      /* Category-modifier classes (`.badge-category-jpop`, etc.) previously
         dimmed the foreground to --rui-fg-muted to match the legacy washed-out
         look. The brief now requires Secondary Pill foreground contrast, so
         the modifiers intentionally inherit `.badge-category`'s color
         (--rui-pill-secondary-fg). They remain in the DOM as future hooks for
         per-category tinting if it's ever wanted, but no longer dim. */

      .result-numbers {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        /* Path A — push vendor-tags row to the bottom of the flex column so
           cards in the same row share an aligned tags baseline regardless of
           title length. */
        margin-top: auto;
        padding-top: 0.4rem;
      }

      /* Vendor-number tags in ResultCard. Per the brief these are decorative
         tags (radius-small, NOT pill) with a CLEAR contrast against the card
         surface. They sit on --rui-pill-secondary-bg so they read as a
         distinct surface from the card itself (--rui-surface). Number value is
         full-contrast --rui-fg; prefix label stays muted.

         Deviations from DESIGN.md §3 Body (documented):
           - Number value: 14px / 500 (vs §3 Body 16px / 400). At 16px three
             tags overflow the card row; 14px keeps a single-line layout while
             remaining readable. Weight 500 compensates for the smaller size.
           - Prefix label: 12px / 500 / 0.6px tracking, uppercase — same
             off-table caption treatment used elsewhere on small inline
             labels.
         These are clickable copy-to-clipboard buttons, so DESIGN.md §4 hover
         (opacity 0.85 + --rui-surface-hover background swap) applies. */
      .badge-number {
        position: relative;
        font-family: var(--rui-font-body);
        font-size: 14px;
        font-weight: 500;
        line-height: 1.5;
        letter-spacing: 0.16px;
        padding: 4px 10px;
        border-radius: var(--rui-radius-small);
        border: 0;
        background: var(--rui-pill-secondary-bg);
        color: var(--rui-fg);
        cursor: pointer;
        text-transform: none;
        transition:
          opacity 120ms ease,
          background 120ms ease;
      }

      .badge-number:hover:not(:disabled) {
        /* DESIGN.md §4 — interactive hover is opacity 0.85 + surface-hover
           background swap. */
        opacity: 0.85;
        background: var(--rui-surface-hover);
      }

      .badge-number:focus-visible {
        outline: none;
        box-shadow: var(--rui-focus-ring);
      }

      .badge-number .badge-label {
        font-family: var(--rui-font-body);
        /* Off-table small uppercase label — see .empty-section-title note. */
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        color: var(--rui-fg-muted);
        margin-right: 0.4rem;
      }

      .badge-number .badge-value {
        /* Full --rui-fg contrast on the number value per the brief. */
        color: var(--rui-fg);
      }

      .badge-disabled {
        opacity: 0.45;
        cursor: not-allowed;
      }

      .badge-disabled .badge-value {
        color: var(--rui-fg-muted);
      }

      .badge-toast {
        position: absolute;
        top: -1.75rem;
        left: 50%;
        transform: translateX(-50%);
        padding: 4px 10px;
        border-radius: var(--rui-radius-pill);
        background: var(--rui-pill-primary-bg);
        color: var(--rui-pill-primary-fg);
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body — 16px / 0.24px (toast is small but still legible) */
        font-size: var(--rui-text-body);
        font-weight: 500;
        letter-spacing: 0.24px;
        text-transform: none;
        white-space: nowrap;
        pointer-events: none;
      }

      /* Visually-hidden helper for aria-live regions. */
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .error-state {
        margin-top: 1rem;
        padding: 1rem 1.25rem;
        border-radius: var(--rui-radius-card);
        background: var(--rui-surface);
      }

      .error-state-headline {
        margin: 0 0 0.5rem 0;
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body Semibold — 16px / 600 / 1.5 / 0.16px */
        font-size: var(--rui-text-body);
        font-weight: 600;
        line-height: 1.5;
        letter-spacing: 0.16px;
        color: var(--rui-fg);
      }

      .error-state-detail {
        margin: 0;
        /* DESIGN.md §3 Body — 16px / 400 / 1.5 / 0.24px */
        font-size: var(--rui-text-body);
        line-height: 1.5;
        letter-spacing: 0.24px;
        color: var(--rui-fg-muted);
      }

      /* DESIGN.md §3 Body — 16px / 400 / 1.5 / 0.24px. The previous all-uppercase
         caption styling is dropped; the DOM has no hook to scope just the
         "DB 업데이트" label, so the whole footer renders as Body. Documented
         deviation from the brief's "DB-update label uppercase" instruction. */
      footer.site-footer {
        max-width: 960px;
        margin: 0 auto;
        padding: 1.5rem 1.25rem;
        border-top: 1px solid var(--rui-border);
        background: var(--rui-surface);
        font-family: var(--rui-font-body);
        font-size: var(--rui-text-body);
        font-weight: 400;
        letter-spacing: 0.24px;
        color: var(--rui-fg-muted);
        line-height: 1.5;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
      }

      .site-footer-sep {
        padding: 0 0.5rem;
      }

      .site-footer-link {
        color: var(--rui-fg);
        text-decoration: none;
      }

      .site-footer-link:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <h1 class="site-title">{title}</h1>
      <p class="site-subtitle">Karaoke Search</p>
    </header>
    <App client:load />
    <Footer />
  </body>
</html>
