---
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { App } from '../components/App';
import Footer from '../components/Footer.astro';
import '../styles/tokens.css';
// Read the corpus at build time so the loading-state label tracks the live
// record count automatically. Build-time only — the JSON is not bundled into
// the client.
const songsPath = fileURLToPath(new URL('../../public/data/songs.json', import.meta.url));
const songCount = (JSON.parse(readFileSync(songsPath, 'utf8')) as unknown[]).length;
const title = '일본 노래 검색기';
const fontsHref = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/fonts/fonts.css`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <link rel="stylesheet" href={fontsHref} />
    <style is:global>
      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background: var(--rui-bg);
        color: var(--rui-fg);
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body — 16px / 1.5 / 0.24px */
        font-size: var(--rui-text-body);
        line-height: 1.5;
        letter-spacing: 0.24px;
      }

      header.site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--rui-bg);
        padding: 1.125rem 1.25rem;
      }

      .site-title {
        margin: 0;
        font-family: var(--rui-font-display);
        /* DESIGN.md §3 Card Title — 32px / 500 / 1.19 / -0.32px (desktop)
           Mobile fallback: §3 Feature Title — 24px / 500 / 1.33 / 0px. */
        font-size: var(--rui-text-feature-title);
        font-weight: 500;
        line-height: 1.33;
        letter-spacing: 0px;
        color: var(--rui-fg);
      }

      @media (min-width: 720px) {
        .site-title {
          font-size: var(--rui-text-card-title);
          line-height: 1.19;
          letter-spacing: -0.32px;
        }
      }

      .site-subtitle {
        margin: 4px 0 0 0;
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body — 16px / 400 / 1.5 / 0.24px */
        font-size: var(--rui-text-body);
        font-weight: 400;
        line-height: 1.5;
        letter-spacing: 0.24px;
        color: var(--rui-fg-muted);
      }

      .tab-bar {
        position: sticky;
        top: var(--header-height, 6rem);
        z-index: 9;
        display: flex;
        gap: 24px;
        width: 100%;
        margin: 0;
        padding: 0;
        background: var(--rui-bg);
        border-bottom: 1px solid var(--rui-border);
      }

      /* Push the first chip group (and any fieldset chip group immediately
         after the tab bar) down 1rem so there is breathing room between the
         tab bar's bottom border and the chip pills. Using a sibling selector
         here rather than `padding-bottom` on `.tab-bar` keeps the bottom
         border flush against the tab buttons — padding would move the border
         downward, away from the buttons, which reads as wrong visually. */
      .tab-bar + .chip-group,
      .tab-bar + fieldset {
        margin-top: 1rem;
      }

      /* Mobile (<720px) — bleed the tab bar edge-to-edge so the bottom border
         spans the full viewport. Negative lateral margins alone are not
         enough: `.tab-bar` declares `width: 100%`, which resolves against
         the parent's CONTENT box and ignores the bled space, so the right
         border still stops at the parent's padding edge. `100vw` is also
         wrong because it includes the scrollbar gutter (documentElement
         width does not), causing horizontal overflow when a scrollbar is
         present. Solution: override `width` to `100% + 2.5rem` so the
         element actually grows into the bled space — independent of
         scrollbar presence. The 2.5rem matches the sum of the two
         negative margins exactly. `padding-left/right: 1.25rem` keeps
         tab-content aligned with the rest of the page column. */
      @media (max-width: 719px) {
        .tab-bar {
          width: calc(100% + 2.5rem);
          margin-left: -1.25rem;
          margin-right: -1.25rem;
          padding-left: 1.25rem;
          padding-right: 1.25rem;
        }
      }

      .tab-button {
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body — 16px. Inactive uses weight 500 (between Body 400
           and Body Semibold 600) so the active/inactive contrast reads. */
        font-size: var(--rui-text-body);
        font-weight: 500;
        padding: 10px 4px;
        background: transparent;
        color: var(--rui-fg-muted);
        border: 0;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        border-radius: 0;
        cursor: pointer;
        outline: none;
        letter-spacing: 0.24px;
        transition:
          color 120ms ease,
          border-color 120ms ease;
      }

      .tab-button:hover:not(:disabled) {
        color: var(--rui-fg);
      }

      .tab-button:focus-visible {
        outline: none;
        box-shadow: var(--rui-focus-ring);
      }

      .tab-button[aria-selected='true'] {
        color: var(--rui-fg);
        /* DESIGN.md §3 Body Semibold — 600 */
        font-weight: 600;
        border-bottom-color: var(--rui-fg);
      }

      .tab-button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      .search-input-wrap {
        position: relative;
        max-width: 640px;
        padding-bottom: 0.5rem;
      }

      .search-input-icon {
        position: absolute;
        top: 50%;
        left: 1.1rem;
        transform: translateY(-50%);
        color: var(--rui-fg-subtle);
        pointer-events: none;
      }

      input.search-input {
        width: 100%;
        max-width: 640px;
        height: 48px;
        padding: 0 1.25rem 0 2.75rem;
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body — 16px / 400 / 0.24px */
        font-size: var(--rui-text-body);
        font-weight: 400;
        letter-spacing: 0.24px;
        color: var(--rui-fg);
        background: var(--rui-surface);
        border: 1px solid var(--rui-border);
        border-radius: var(--rui-radius-pill);
        outline: none;
        transition:
          border-color 120ms ease,
          background 120ms ease;
      }

      input.search-input::placeholder {
        color: var(--rui-fg-subtle);
      }

      input.search-input:focus-visible {
        outline: none;
        box-shadow: var(--rui-focus-ring);
        border-color: var(--rui-border-strong);
      }

      main.results {
        padding: 1.25rem;
        max-width: 960px;
        margin: 0 auto;
      }

      main.results .loading,
      main.results .error {
        color: var(--rui-fg-muted);
        /* DESIGN.md §3 Body — 16px */
        font-size: var(--rui-text-body);
      }

      main.results .error {
        color: var(--rui-fg);
      }

      @keyframes karaoke-dot-cycle {
        0%,
        100% {
          opacity: 0.2;
        }
        50% {
          opacity: 1;
        }
      }

      .loading-dot {
        display: inline-block;
        animation: karaoke-dot-cycle 1.2s infinite ease-in-out;
        font-weight: 600;
      }

      .loading-dot:nth-child(1) {
        animation-delay: 0s;
      }
      .loading-dot:nth-child(2) {
        animation-delay: 0.4s;
      }
      .loading-dot:nth-child(3) {
        animation-delay: 0.8s;
      }

      .chip-group {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 0.75rem 0 1.25rem;
        padding: 0;
        border: 0;
      }

      .chip-group-legend {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        border: 0;
      }

      /* DESIGN.md §4 Secondary Light Pill — 14px 32px padding, 9999px radius.
         All `.chip` instances render as Secondary pills by default; the vendor
         chip group (`.chip-group-vendor`) overrides with the §4 Outlined Pill
         treatment to differentiate visual rank from category chips. */
      .chip {
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body Semibold — 16px / 600 / 1.5 / 0.16px */
        font-size: var(--rui-text-body);
        font-weight: 600;
        line-height: 1.5;
        letter-spacing: 0.16px;
        padding: 14px 32px;
        border-radius: var(--rui-radius-pill);
        border: 2px solid transparent;
        background: var(--rui-pill-secondary-bg);
        color: var(--rui-pill-secondary-fg);
        cursor: pointer;
        transition: opacity 120ms ease;
        white-space: nowrap;     /* never wrap chip text */
        flex-shrink: 0;          /* preserve natural width in flex/scroll containers */
      }

      .chip:hover {
        /* DESIGN.md §4 — pill hover is opacity 0.85 */
        opacity: 0.85;
      }

      .chip:focus-visible {
        outline: none;
        box-shadow: var(--rui-focus-ring);
      }

      .chip-selected,
      .chip-selected:hover {
        background: var(--rui-pill-primary-bg);
        color: var(--rui-pill-primary-fg);
      }

      /* DESIGN.md §4 Outlined Pill — transparent BG, 2px solid border-strong. */
      .chip-group-vendor .chip {
        background: var(--rui-pill-ghost-bg);
        color: var(--rui-fg);
        border-color: var(--rui-border-strong);
      }

      .chip-group-vendor .chip-selected,
      .chip-group-vendor .chip-selected:hover {
        background: var(--rui-pill-primary-bg);
        color: var(--rui-pill-primary-fg);
        border-color: var(--rui-pill-primary-bg);
      }

      .empty-state {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
      }

      /* Off-table small uppercase label — DESIGN.md §3 has no caption scale.
         Documented deviation: 12px Inter 500 uppercase with 0.6px tracking. */
      .empty-section-title {
        margin: 16px 0 12px;
        font-family: var(--rui-font-body);
        font-size: 12px;
        font-weight: 500;
        line-height: 1.4;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        color: var(--rui-fg-muted);
      }

      .empty-section-title-jpop,
      .empty-section-title-vocaloid,
      .empty-section-title-anime,
      .empty-favorites-title {
        color: var(--rui-fg-muted);
      }

      /* DESIGN.md §5 — base 8px spacing scale. Pills wrap rather than scroll. */
      .empty-section-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .empty-section-placeholder {
        margin: 0;
        color: var(--rui-fg-muted);
        /* DESIGN.md §3 Body — 16px */
        font-size: var(--rui-text-body);
      }

      .no-results {
        text-align: center;
        color: var(--rui-fg-muted);
        padding: 2rem 1rem;
      }

      .no-results-title {
        margin: 0 0 0.5rem;
        font-family: var(--rui-font-display);
        /* DESIGN.md §3 Feature Title — 24px / 500 / 1.33 / 0px */
        font-size: var(--rui-text-feature-title);
        font-weight: 500;
        line-height: 1.33;
        letter-spacing: 0px;
        color: var(--rui-fg);
      }

      .favorites-empty {
        text-align: center;
        color: var(--rui-fg-muted);
        padding: 2rem 1rem;
        /* DESIGN.md §3 Body — 16px */
        font-size: var(--rui-text-body);
        line-height: 1.5;
        letter-spacing: 0.24px;
      }

      .result-list {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.75rem;
        list-style: none;
        margin: 0;
        padding: 0;
        /* Path A — stretch all cards in a row to the tallest card's height so
           variable-height titles do not break the grid. The vendor-numbers row
           inside `.result-card` then uses `margin-top: auto` to flush to the
           card's bottom edge. Result: the bottom edge of every card in a row
           aligns. */
        align-items: stretch;
      }

      @media (min-width: 720px) {
        .result-list {
          grid-template-columns: 1fr 1fr;
        }
      }

      /* Stretch the <li> wrapper to fill the grid track so the inner card can
         claim full row height. Without this, `align-items: stretch` on the
         grid stretches the <li> but `.result-card` would still hug its content
         inside that <li> unless the <li> propagates height. */
      .result-list-item {
        display: flex;
      }

      .result-list-item .result-card {
        flex: 1;
      }

      @media (max-width: 719px) {
        /* Mobile compact sizing — surgical scale-down from DESIGN.md tablet+ spec.
           Tablet+ (≥720px) retains the generous DESIGN.md 14px 32px / 16px 600 spec.
           Mobile chip sizing: 6px 14px / 14px 500. */

        /* Category + vendor chips */
        .chip {
          padding: 6px 14px;
          font-size: 14px;
          font-weight: 500;
          letter-spacing: 0.16px;
        }

        /* In-row gap between chips (category row and vendor row each).
           Horizontal-scroll affordance mirrors .empty-section-chips mobile
           rule — edge-bleed to screen edge, thin scrollbar, no wrap. */
        .chip-group {
          gap: 6px;
          flex-wrap: nowrap;       /* don't break to a second row */
          overflow-x: auto;        /* allow horizontal scroll if needed */
          margin-left: -1.25rem;
          margin-right: -1.25rem;
          padding-left: 1.25rem;
          padding-right: 1.25rem;
          padding-bottom: 0;
          scrollbar-width: none;   /* Firefox */
          -webkit-overflow-scrolling: touch;
        }

        /* Inter-row gap between category chip row and vendor chip row */
        .chip-group + .chip-group {
          margin-top: 8px;
        }

        /* Featured-artist strip — one-row horizontal scroll, no wrap.
           Edge-bleed: margin pulls the scroll track to the screen edge;
           padding-left restores the content alignment so the first chip
           aligns with the rest of the page content. */
        .empty-section-chips {
          flex-wrap: nowrap;
          overflow-x: auto;
          gap: 6px;
          padding-bottom: 0;
          -webkit-overflow-scrolling: touch;
          margin-left: -1.25rem;
          margin-right: -1.25rem;
          padding-left: 1.25rem;
          padding-right: 1.25rem;
          scrollbar-width: none;   /* Firefox */
        }

        /* Tighten the gap between chip block and the first featured-strip section */
        .chip-group ~ .empty-state {
          margin-top: 12px;
        }

        .result-numbers {
          gap: 0.5rem;
          padding: 0.4rem 0;
        }

        .favorite-star {
          min-width: 44px;
          min-height: 44px;
        }

        /* Hide scrollbar on WebKit/Blink browsers (Chrome, Safari, Edge,
           Samsung Internet). overflow-x: auto is preserved — touch-swipe
           still works; only the visible scrollbar track is removed. */
        .empty-section-chips::-webkit-scrollbar,
        .chip-group::-webkit-scrollbar {
          display: none;           /* Chrome / Safari / Edge / Samsung Internet */
        }
      }

      .result-card {
        position: relative;
        background: var(--rui-surface);
        border-radius: var(--rui-radius-card);
        /* DESIGN.md §5 spacing scale — 16px (was 14px 16px which is off-scale
           on the vertical axis). 16px on both axes matches the Revolut card
           rhythm. */
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        /* Path A — fill the grid track height so all cards in a row align at
           the bottom edge. */
        height: 100%;
        transition: background 120ms ease;
      }

      .result-card:hover {
        background: var(--rui-surface-hover);
      }

      .favorite-star {
        position: absolute;
        top: 0.75rem;
        right: 0.85rem;
        font-family: var(--rui-font-body);
        font-size: 1.125rem;
        line-height: 1;
        background: transparent;
        border: 0;
        padding: 0.25rem 0.4rem;
        cursor: pointer;
        /* Inactive: visibly present but de-emphasized — DESIGN.md §2 Mid Slate
           via --rui-fg-subtle. */
        color: var(--rui-fg-subtle);
        transition:
          color 120ms ease,
          opacity 120ms ease;
      }

      .favorite-star:hover {
        /* DESIGN.md §4 — interactive hover is opacity 0.85. */
        opacity: 0.85;
      }

      .favorite-star:focus-visible {
        outline: none;
        box-shadow: var(--rui-focus-ring);
        border-radius: var(--rui-radius-small);
      }

      /* Active: full --rui-fg foreground per brief. */
      .favorite-star-on {
        color: var(--rui-fg);
      }

      .favorite-star-on:hover {
        color: var(--rui-fg);
        opacity: 0.85;
      }

      .result-title {
        margin: 0;
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body Semibold — 16px / 600 / 1.5 / 0.16px */
        font-size: var(--rui-text-body);
        font-weight: 600;
        line-height: 1.5;
        letter-spacing: 0.16px;
        color: var(--rui-fg);
        padding-right: 2.25rem;
      }

      .result-artist {
        color: var(--rui-fg-muted);
        /* DESIGN.md §3 Body — 16px / 400 / 1.5 / 0.24px. Strict scale; if the
           list density looks too dense, the brief calls for flagging — do not
           silently shrink. */
        font-size: var(--rui-text-body);
        font-weight: 400;
        line-height: 1.5;
        letter-spacing: 0.24px;
      }

      .result-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 4px 10px;
        border-radius: var(--rui-radius-small);
        background: var(--rui-surface);
        font-family: var(--rui-font-body);
        /* Off-table small uppercase label — DESIGN.md §3 has no caption scale.
           Documented deviation: 12px Inter 500 uppercase with 0.6px tracking. */
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        color: var(--rui-fg-muted);
      }

      /* DESIGN.md §4 Secondary Pill treatment — scaled down for inline content
         tag use. Deviations from §4 baseline (documented):
           - Padding: 6px 14px (vs §4's 14px 32px) — this is an inline tag
             inside a card, NOT a primary CTA. Generous CTA padding would
             dominate the card row.
           - Typography: 12px / 500 / 0.6px tracking, uppercase (vs §3 Body
             Semibold 16px / 600 / 0.16px) — picks the small uppercase caption
             treatment used elsewhere on small inline labels (`.badge-label`,
             `.empty-section-title`). 16px would overflow the card row at 3
             tags + a category chip.
           - No border (per brief — Secondary Pill has no border in either
             theme).
           - No opacity hover — this is a non-interactive `<span>`. */
      .badge-category {
        background: var(--rui-pill-secondary-bg);
        color: var(--rui-pill-secondary-fg);
        border-radius: var(--rui-radius-pill);
        padding: 6px 14px;
        text-transform: uppercase;
      }

      /* Category-modifier classes (`.badge-category-jpop`, etc.) previously
         dimmed the foreground to --rui-fg-muted to match the legacy washed-out
         look. The brief now requires Secondary Pill foreground contrast, so
         the modifiers intentionally inherit `.badge-category`'s color
         (--rui-pill-secondary-fg). They remain in the DOM as future hooks for
         per-category tinting if it's ever wanted, but no longer dim. */

      .result-numbers {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        /* Path A — push vendor-tags row to the bottom of the flex column so
           cards in the same row share an aligned tags baseline regardless of
           title length. */
        margin-top: auto;
        padding-top: 0.4rem;
      }

      /* Vendor-number tags in ResultCard. Per the brief these are decorative
         tags (radius-small, NOT pill) with a CLEAR contrast against the card
         surface. They sit on --rui-pill-secondary-bg so they read as a
         distinct surface from the card itself (--rui-surface). Number value is
         full-contrast --rui-fg; prefix label stays muted.

         Deviations from DESIGN.md §3 Body (documented):
           - Number value: 14px / 500 (vs §3 Body 16px / 400). At 16px three
             tags overflow the card row; 14px keeps a single-line layout while
             remaining readable. Weight 500 compensates for the smaller size.
           - Prefix label: 12px / 500 / 0.6px tracking, uppercase — same
             off-table caption treatment used elsewhere on small inline
             labels.
         These are clickable copy-to-clipboard buttons, so DESIGN.md §4 hover
         (opacity 0.85 + --rui-surface-hover background swap) applies. */
      .badge-number {
        position: relative;
        font-family: var(--rui-font-body);
        font-size: 14px;
        font-weight: 500;
        line-height: 1.5;
        letter-spacing: 0.16px;
        /* Match `.badge-category`'s slim 6px 14px profile so the TJ/KY/JOY
           pills read at the same vertical height as the category tag inside
           a result card. Mobile previously also applied `min-height: 44px`
           for tap-target generosity but it forced the row to ~44px tall — out
           of rhythm with the slim category tag. The 14px font + 6px×2 padding
           gives ~33px which still meets generic touch-target heuristics. */
        padding: 6px 14px;
        border-radius: var(--rui-radius-small);
        border: 0;
        background: var(--rui-pill-secondary-bg);
        color: var(--rui-fg);
        cursor: pointer;
        text-transform: none;
        transition:
          opacity 120ms ease,
          background 120ms ease;
      }

      .badge-number:hover:not(:disabled) {
        /* DESIGN.md §4 — interactive hover is opacity 0.85 + surface-hover
           background swap. */
        opacity: 0.85;
        background: var(--rui-surface-hover);
      }

      .badge-number:focus-visible {
        outline: none;
        box-shadow: var(--rui-focus-ring);
      }

      .badge-number .badge-label {
        font-family: var(--rui-font-body);
        /* Off-table small uppercase label — see .empty-section-title note. */
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        color: var(--rui-fg-muted);
        margin-right: 0.4rem;
      }

      .badge-number .badge-value {
        /* Full --rui-fg contrast on the number value per the brief. */
        color: var(--rui-fg);
      }

      .badge-disabled {
        opacity: 0.45;
        cursor: not-allowed;
      }

      .badge-disabled .badge-value {
        color: var(--rui-fg-muted);
      }

      .badge-toast {
        position: absolute;
        top: -1.75rem;
        left: 50%;
        transform: translateX(-50%);
        padding: 4px 10px;
        border-radius: var(--rui-radius-pill);
        background: var(--rui-pill-primary-bg);
        color: var(--rui-pill-primary-fg);
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body — 16px / 0.24px (toast is small but still legible) */
        font-size: var(--rui-text-body);
        font-weight: 500;
        letter-spacing: 0.24px;
        text-transform: none;
        white-space: nowrap;
        pointer-events: none;
      }

      /* Visually-hidden helper for aria-live regions. */
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .error-state {
        margin-top: 1rem;
        padding: 1rem 1.25rem;
        border-radius: var(--rui-radius-card);
        background: var(--rui-surface);
      }

      .error-state-headline {
        margin: 0 0 0.5rem 0;
        font-family: var(--rui-font-body);
        /* DESIGN.md §3 Body Semibold — 16px / 600 / 1.5 / 0.16px */
        font-size: var(--rui-text-body);
        font-weight: 600;
        line-height: 1.5;
        letter-spacing: 0.16px;
        color: var(--rui-fg);
      }

      .error-state-detail {
        margin: 0;
        /* DESIGN.md §3 Body — 16px / 400 / 1.5 / 0.24px */
        font-size: var(--rui-text-body);
        line-height: 1.5;
        letter-spacing: 0.24px;
        color: var(--rui-fg-muted);
      }

      /* Footer — three-row layout: brand label, bilingual disclaimer, metadata.
         Mobile-first sizing with a tablet+ bump at the 720px breakpoint. Each
         metadata item is `white-space: nowrap` so individual tokens never break
         mid-word; the row wraps at bullet-separator boundaries via flex-wrap. */
      footer.site-footer {
        max-width: 960px;
        margin: 0 auto;
        padding: 24px 1.25rem 32px;
        border-top: 1px solid var(--rui-border);
        background: var(--rui-surface);
        font-family: var(--rui-font-body);
        color: var(--rui-fg-muted);
        display: flex;
        flex-direction: column;
        align-items: flex-start;
      }

      @media (min-width: 720px) {
        footer.site-footer {
          padding: 32px 1.25rem 40px;
        }
      }

      /* Row 1 — small uppercase brand label. */
      .site-footer-brand {
        font-family: var(--rui-font-body);
        font-size: 11px;
        font-weight: 500;
        line-height: 1.4;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: var(--rui-fg-muted);
        white-space: nowrap;
        flex-shrink: 0;
      }

      /* Row 2 — bilingual disclaimer. Korean line + English line stacked,
         constrained to 60ch on wide screens so the line length stays readable. */
      .site-footer-disclaimer {
        margin: 12px 0 0;
        max-width: 60ch;
        font-family: var(--rui-font-body);
        font-size: 13px;
        font-weight: 400;
        line-height: 1.5;
        color: var(--rui-fg-muted);
      }

      @media (min-width: 720px) {
        .site-footer-disclaimer {
          margin-top: 16px;
        }
      }

      .site-footer-disclaimer-ko,
      .site-footer-disclaimer-en {
        display: block;
      }

      /* Row 3 — metadata bullets. flex-wrap allows narrow viewports to break
         the row at bullet boundaries; each `.site-footer-meta-item` is
         `white-space: nowrap` so individual tokens never break mid-word. */
      .site-footer-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 4px 8px;
        margin-top: 12px;
        font-family: var(--rui-font-body);
        font-size: 12px;
        font-weight: 400;
        line-height: 1.5;
        letter-spacing: 0.16px;
        color: var(--rui-fg-subtle);
      }

      @media (min-width: 720px) {
        .site-footer-meta {
          margin-top: 16px;
        }
      }

      .site-footer-meta-item {
        white-space: nowrap;
      }

      .site-footer-meta-sep {
        color: var(--rui-fg-subtle);
      }

      .site-footer-link {
        color: var(--rui-fg);
        text-decoration: none;
      }

      .site-footer-link:hover {
        text-decoration: underline;
      }

      .site-footer-link:focus-visible {
        outline: none;
        box-shadow: var(--rui-focus-ring);
        border-radius: 2px;
      }

      /* Mobile (<720px) — drop one notch on each row's font-size; disclaimer
         loses its 60ch constraint to fill the slim viewport. */
      @media (max-width: 719px) {
        .site-footer-brand {
          font-size: 10px;
        }

        .site-footer-disclaimer {
          max-width: 100%;
          font-size: 12px;
        }

        .site-footer-meta {
          font-size: 11px;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <h1 class="site-title">{title}</h1>
      <p class="site-subtitle">Karaoke Search</p>
    </header>
    <App client:load songCount={songCount} />
    <Footer />
  </body>
</html>
