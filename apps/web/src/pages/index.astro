---
import { App } from '../components/App';
const title = '노래방 검색기';
---

<!doctype html>
<html lang="ko" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <style is:global>
      :root {
        --bg: #0b0d10;
        --bg-elev: #14171c;
        --bg-card: #161a20;
        --fg: #e6e8eb;
        --fg-muted: #8a93a0;
        --accent: #8ab4ff;
        --accent-fg: #0b0d10;
        --border: #232831;
        --border-strong: #353c47;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family:
          system-ui,
          -apple-system,
          'Segoe UI',
          'Noto Sans KR',
          'Noto Sans JP',
          sans-serif;
        font-size: 16px;
        line-height: 1.5;
      }

      header.site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--bg-elev);
        border-bottom: 1px solid var(--border);
        padding: 1rem 1.25rem;
      }

      header.site-header h1 {
        margin: 0 0 0.75rem;
        font-size: 1.4rem;
        font-weight: 650;
        letter-spacing: -0.01em;
      }

      input.search-input {
        width: 100%;
        max-width: 640px;
        padding: 0.6rem 0.85rem;
        font-size: 1rem;
        color: var(--fg);
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        outline: none;
      }

      input.search-input:focus {
        border-color: var(--accent);
      }

      main.results {
        padding: 1.25rem;
        max-width: 960px;
        margin: 0 auto;
      }

      main.results .loading,
      main.results .error {
        color: var(--fg-muted);
        font-size: 0.95rem;
      }

      main.results .error {
        color: #ff8a8a;
      }

      .chip-group {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 0.75rem 0 1.25rem;
        padding: 0;
        border: 0;
      }

      .chip-group-legend {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        border: 0;
      }

      .chip {
        font: inherit;
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
        border: 1px solid var(--border-strong);
        background: var(--bg-elev);
        color: var(--fg-muted);
        cursor: pointer;
      }

      .chip:hover {
        color: var(--fg);
      }

      .chip-selected {
        background: var(--accent);
        color: var(--accent-fg);
        border-color: var(--accent);
      }

      .empty-state {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .empty-section-title {
        margin: 0 0 0.5rem;
        font-size: 1rem;
        color: var(--fg-muted);
        font-weight: 600;
      }

      .empty-section-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .empty-section-placeholder {
        margin: 0;
        color: var(--fg-muted);
        font-size: 0.9rem;
      }

      .featured-chip {
        font: inherit;
        padding: 0.35rem 0.75rem;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: var(--bg-elev);
        color: var(--fg);
        cursor: pointer;
      }

      .featured-chip:hover {
        border-color: var(--accent);
      }

      .no-results {
        color: var(--fg-muted);
      }

      .no-results-title {
        margin: 0 0 0.5rem;
        font-size: 1.05rem;
        color: var(--fg);
      }

      .no-results-hint {
        margin: 0;
        font-size: 0.9rem;
      }

      .result-list {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.75rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      @media (min-width: 720px) {
        .result-list {
          grid-template-columns: 1fr 1fr;
        }
      }

      .result-list-item {
        display: block;
      }

      .result-card {
        position: relative;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1rem 1.1rem;
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
      }

      .result-title {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 650;
        line-height: 1.35;
      }

      .result-artist {
        color: var(--fg-muted);
        font-size: 0.9rem;
      }

      .result-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.18rem 0.5rem;
        border-radius: 4px;
        border: 1px solid var(--border);
        background: var(--bg-elev);
        font-size: 0.78rem;
        color: var(--fg-muted);
      }

      .badge-category {
        text-transform: lowercase;
      }

      .badge-category-jpop {
        color: #8ab4ff;
        border-color: color-mix(in srgb, #8ab4ff 40%, var(--border));
      }

      .badge-category-vocaloid {
        color: #c89bff;
        border-color: color-mix(in srgb, #c89bff 40%, var(--border));
      }

      .badge-category-anime {
        color: #ffb37a;
        border-color: color-mix(in srgb, #ffb37a 40%, var(--border));
      }

      .result-numbers {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.15rem;
      }

      .badge-number {
        position: relative;
        font: inherit;
        font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace;
        font-size: 0.86rem;
        padding: 0.3rem 0.6rem;
        border-radius: 4px;
        border: 1px solid var(--border-strong);
        background: var(--bg-elev);
        color: var(--fg);
        cursor: pointer;
      }

      .badge-number:hover:not(:disabled) {
        border-color: var(--accent);
      }

      .badge-number .badge-label {
        font-weight: 600;
        color: var(--fg-muted);
        margin-right: 0.25rem;
      }

      .badge-disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      .badge-disabled .badge-value {
        color: var(--fg-muted);
      }

      .badge-toast {
        position: absolute;
        top: -1.6rem;
        left: 50%;
        transform: translateX(-50%);
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
        background: var(--accent);
        color: var(--accent-fg);
        font-size: 0.72rem;
        white-space: nowrap;
        pointer-events: none;
      }

      /* Visually-hidden helper for aria-live regions. */
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .error-state {
        margin-top: 1rem;
        padding: 1rem;
        border-radius: 8px;
        border: 1px solid var(--accent);
        background: color-mix(in srgb, var(--accent) 8%, transparent);
      }

      .error-state-headline {
        margin: 0 0 0.5rem 0;
        font-weight: 600;
      }

      .error-state-detail {
        margin: 0;
        font-size: 0.85rem;
        opacity: 0.8;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <h1>{title}</h1>
    </header>
    <App client:load />
  </body>
</html>
