---
import { execSync } from 'node:child_process';
import { existsSync } from 'node:fs';
import { dirname, join, parse, resolve } from 'node:path';
import { fileURLToPath } from 'node:url';
import { formatDbDate } from '../lib/footer-date.js';

// Resolve the repo root by walking up for a `.git` marker. Audit found the
// prior `../../../..` from `import.meta.url` was brittle: any future relocation
// of this file (or change in Astro's build layout) silently lands in the wrong
// directory. The `.git` walk is layout-independent.
function findRepoRoot(start: string): string | null {
  let dir = resolve(start);
  const root = parse(dir).root;
  while (dir !== root) {
    if (existsSync(join(dir, '.git'))) return dir;
    dir = dirname(dir);
  }
  return null;
}

const repoRoot =
  findRepoRoot(fileURLToPath(import.meta.url)) ?? findRepoRoot(process.cwd()) ?? process.cwd();

// Surface a build-config bug: if neither the source-tree walk nor the cwd walk
// finds a `.git` marker, the git command below will run from `process.cwd()`
// and likely return empty. Warn unconditionally — this is not environment-
// dependent the way the missing-git-output case is.
if (findRepoRoot(fileURLToPath(import.meta.url)) === null && findRepoRoot(process.cwd()) === null) {
  console.warn(
    '[Footer] could not resolve repo root via .git walk from import.meta.url or process.cwd();',
    `falling back to process.cwd()=${process.cwd()}`,
  );
}

let gitOutput = '';
try {
  gitOutput = execSync('git log -1 --format=%cs -- apps/web/public/data/songs.json', {
    cwd: repoRoot,
    encoding: 'utf8',
    stdio: ['ignore', 'pipe', 'ignore'],
  });
} catch (err) {
  // git unavailable, shallow checkout, or path not in history — fall through.
  // In CI an empty result is a build-time signal: surface it as a warning so
  // the deploy log captures the regression. Locally, swallow silently.
  if (process.env.CI === 'true') {
    console.warn(
      '[Footer] git log failed for songs.json — date will render empty:',
      err instanceof Error ? err.message : err,
    );
  }
}

const dbDate = formatDbDate(gitOutput, process.env.SOURCE_DATE_EPOCH);
---

<footer class="site-footer">
  <div class="site-footer-brand">KARAOKE SEARCH</div>
  <p class="site-footer-disclaimer">
    <span class="site-footer-disclaimer-ko">본 검색 결과는 참고용이며 실제 노래방 기기와 다를 수 있습니다.</span>
    <span class="site-footer-disclaimer-en">Results are for reference; the actual karaoke machine may differ.</span>
  </p>
  <div class="site-footer-meta">
    {dbDate !== '' && (
      <>
        <span class="site-footer-meta-item">DB 업데이트 {dbDate}</span>
        <span class="site-footer-meta-sep" aria-hidden="true">·</span>
      </>
    )}
    <span class="site-footer-meta-item">MIT</span>
    <span class="site-footer-meta-sep" aria-hidden="true">·</span>
    <a
      class="site-footer-meta-item site-footer-link"
      href="https://github.com/ghkim887/karaoke-search/issues"
      target="_blank"
      rel="noreferrer noopener"
    >
      문제 보고 ↗
    </a>
    <span class="site-footer-meta-sep" aria-hidden="true">·</span>
    <a
      class="site-footer-meta-item site-footer-link"
      href="https://github.com/ghkim887/karaoke-search"
      target="_blank"
      rel="noreferrer noopener"
    >
      GitHub ↗
    </a>
  </div>
</footer>
